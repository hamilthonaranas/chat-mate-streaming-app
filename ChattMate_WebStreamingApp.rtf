\f1\u-10179?\u-8764?\u-497?\f2  \f0 Relational Database Schema (PostgreSQL)\par
To handle user state, age verification flags, financial token ledgers, and live streaming sessions, you can use the following database layout:\par
\par
SQL\par
-- Enums for state control\par
CREATE TYPE user_role AS ENUM ('VIEWER', 'BROADCASTER', 'ADMIN');\par
CREATE TYPE kyc_status AS ENUM ('PENDING', 'APPROVED', 'REJECTED');\par
CREATE TYPE stream_status AS ENUM ('IDLE', 'LIVE', 'OFFLINE');\par
\par
-- 1. USERS TABLE\par
CREATE TABLE users (\par
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),\par
    email VARCHAR(255) UNIQUE NOT NULL,\par
    google_id VARCHAR(255) UNIQUE NOT NULL,\par
    display_name VARCHAR(100) NOT NULL,\par
    role user_role DEFAULT 'VIEWER',\par
    token_balance INT DEFAULT 0 CHECK (token_balance >= 0),\par
    is_adult_verified BOOLEAN DEFAULT FALSE,\par
    created_at TIMESTAMP WITH TIME ZONE DEFAULT CURRENT_TIMESTAMP\par
);\par
\par
-- 2. KYC VERIFICATION LOGS (Crucial for PH legal audits)\par
CREATE TABLE kyc_verifications (\par
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),\par
    user_id UUID REFERENCES users(id) ON DELETE CASCADE,\par
    provider_session_id VARCHAR(255) NOT NULL, -- e.g., Sumsub/Smile ID reference\par
    status kyc_status DEFAULT 'PENDING',\par
    id_type_detected VARCHAR(50),             -- e.g., "PH_NATIONAL_ID"\par
    rejection_reason TEXT,\par
    verified_at TIMESTAMP WITH TIME ZONE,\par
    updated_at TIMESTAMP WITH TIME ZONE DEFAULT CURRENT_TIMESTAMP\par
);\par
\par
-- 3. LIVE STREAMS TABLE\par
CREATE TABLE streams (\par
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),\par
    broadcaster_id UUID REFERENCES users(id) ON DELETE CASCADE,\par
    room_name VARCHAR(255) UNIQUE NOT NULL,    -- Maps directly to LiveKit Room Name\par
    title VARCHAR(255),\par
    status stream_status DEFAULT 'IDLE',\par
    current_viewer_count INT DEFAULT 0,\par
    tokens_earned_this_session INT DEFAULT 0,\par
    started_at TIMESTAMP WITH TIME ZONE,\par
    ended_at TIMESTAMP WITH TIME ZONE\par
);\par
\par
-- 4. TOKEN TRANSACTION LEDGER (Tracks tipping & financial transactions)\par
CREATE TABLE token_transactions (\par
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),\par
    sender_id UUID REFERENCES users(id),\par
    receiver_id UUID REFERENCES users(id),\par
    stream_id UUID REFERENCES streams(id),\par
    amount INT NOT NULL CHECK (amount > 0),\par
    created_at TIMESTAMP WITH TIME ZONE DEFAULT CURRENT_TIMESTAMP\par
);\par
\par
-- Optimization Indexes\par
CREATE INDEX idx_users_google_id ON users(google_id);\par
CREATE INDEX idx_streams_status ON streams(status) WHERE status = 'LIVE';\par
CREATE INDEX idx_kyc_user ON kyc_verifications(user_id);\par
