\par
To protect your ChattMate platform, the middleware needs to intercept requests before they reach your sensitive pages (like Profile Edit or Live Broadcast). If the user isn't verified or hasn't topped up, the middleware redirects them to your payment/verification page.\par
\par
1. Create the Middleware (middleware.ts)\par
Place this file in your project root (same level as app/ folder). It will intercept traffic to the routes you define as "protected."\par
\par
TypeScript\par
import \{ NextResponse \} from 'next/server';\par
import type \{ NextRequest \} from 'next/server';\par
\par
export async function middleware(request: NextRequest) \{\par
  // 1. Get the session/user cookie (assuming you use NextAuth or similar)\par
  const sessionToken = request.cookies.get('session-token');\par
\par
  // 2. Define protected routes\par
  const isProtectedPath = request.nextUrl.pathname.startsWith('/profile/edit') || \par
                          request.nextUrl.pathname.startsWith('/stream/broadcast');\par
\par
  if (isProtectedPath) \{\par
    if (!sessionToken) \{\par
      return NextResponse.redirect(new URL('/login', request.url));\par
    \}\par
\par
    // 3. Perform a quick verification check via an internal API\par
    // Note: You would typically verify the JWT claims here \par
    // to see if the user has 'isVerified' and 'hasDeposited' flags\par
    const user = await verifyUserStatus(sessionToken.value);\par
\par
    if (!user.isVerifiedAdult || !user.hasDeposited) \{\par
      return NextResponse.redirect(new URL('/account-gated', request.url));\par
    \}\par
  \}\par
\par
  return NextResponse.next();\par
\}\par
\par
// Helper to simulate DB check (in production, use a cached JWT check)\par
async function verifyUserStatus(token: string) \{\par
  // Replace with actual logic to decode JWT or fetch from Redis\par
  return \{ isVerifiedAdult: true, hasDeposited: false \};\par
\}\par
\par
export const config = \{\par
  matcher: ['/profile/edit/:path*', '/stream/broadcast/:path*'],\par
\};\par
